# ============================================================
# PrivateStream NEAR - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# NEAR PROTOCOL CONFIGURATION
# ============================================================
NEXT_PUBLIC_NEAR_NETWORK=testnet
NEXT_PUBLIC_NEAR_NODE_URL=https://rpc.testnet.near.org
NEXT_PUBLIC_NEAR_WALLET_URL=https://wallet.testnet.near.org
NEXT_PUBLIC_NEAR_HELPER_URL=https://helper.testnet.near.org

# Your deployed NEAR smart contract account ID
# Example: privatestream.testnet
NEXT_PUBLIC_CONTRACT_NAME=

# ============================================================
# PINATA IPFS STORAGE
# ============================================================
# Get from: https://app.pinata.cloud/keys
PINATA_JWT=
PINATA_GATEWAY_URL=https://gateway.pinata.cloud

# ============================================================
# ENCRYPTION (SERVER-SIDE ONLY - NEVER EXPOSE TO CLIENT)
# ============================================================
# 32-byte hex string for AES-256-GCM encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=

# ============================================================
# PLATFORM CONFIGURATION
# ============================================================
# NEAR account that receives platform fees
PLATFORM_TREASURY_ACCOUNT=treasury.testnet

# Revenue cap per campaign in USD
REVENUE_CAP_USD=20

# Platform fee percentage (10 = 10%)
PLATFORM_FEE_PERCENTAGE=10

# Fallback NEAR/USD price if oracle unavailable
NEAR_USD_FALLBACK=5
